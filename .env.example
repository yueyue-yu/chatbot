# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for your OpenAI-compatible provider
OPENAI_COMPAT_BASE_URL=https://api.example.com/v1
OPENAI_COMPAT_API_KEY=****
OPENAI_COMPAT_DEFAULT_MODEL=your-model-id

# shared capabilities for the configured provider
OPENAI_COMPAT_SUPPORTS_VISION=false
OPENAI_COMPAT_SUPPORTS_TOOLS=true
OPENAI_COMPAT_SUPPORTS_REASONING=false

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****
